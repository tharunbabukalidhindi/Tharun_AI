# ─────────────────────────────────────────────────────────
#  AI Video Agent — Environment Variables
#  Copy this to .env and fill in your values
# ─────────────────────────────────────────────────────────

# ── Gemini API (https://aistudio.google.com) ─────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Cartesia TTS (https://cartesia.ai) ───────────────────
CARTESIA_API_KEY=your_cartesia_api_key_here
# Voice options: Sonic (default), or get voice IDs from Cartesia dashboard
CARTESIA_VOICE_ID=a0e99841-438c-4a64-b679-ae501e7d6091

# ── LiveKit (https://cloud.livekit.io) ───────────────────
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# ── GPU Server (configure after Lightning AI setup) ───────
GPU_WS_URL=ws://your-gpu-ip:8000/stream
GPU_API_URL=http://your-gpu-ip:8000

# ── App Settings ─────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
AGENT_NAME=Mr. Brain

# ── Persona Image ─────────────────────────────────────────
# Place your persona image at: persona/persona.jpg
PERSONA_IMAGE_PATH=../persona/persona.jpg
